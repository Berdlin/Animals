# Environment Variables for Feral Pursuit
# Copy this file to .env and fill in your actual values
# DO NOT commit the actual .env file to git

# Neon PostgreSQL Database URL
# Get this from your Neon dashboard: https://console.neon.tech
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_HOST/neondb?sslmode=require

# Environment
NODE_ENV=development

# Port (optional - defaults to 3000)
PORT=3000
